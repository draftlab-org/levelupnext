---
import LuFooter from '@components/levelup/LuFooter.astro';
import LuHeader from '@components/levelup/LuHeader.astro';
import LuNav from '@components/levelup/LuNav.astro';
import LuSearch from '@components/levelup/LuSearch.tsx';
import BaseLayout from '@layouts/BaseLayout.astro';

export interface Props {
  title: string;
  description?: string;
  image?: ImageMetadata;
  showNav?: boolean;
}

const { title, description, image, showNav = true } = Astro.props;
const hasToc = Astro.slots.has('toc');
---

<BaseLayout title={title} description={description} image={image}>
	<div class="flex min-h-screen w-full flex-col bg-sand">
		{
			/* Full-width header & nav bars; their inner content is held to a
		    centred max-width for sensible margins. */
		}
		<LuHeader />
		{showNav && <LuNav />}

		{
			/* Body: the article column keeps its width, the ToC floats to its right
		    on the sand background (xl+). */
		}
		<div class="mx-auto flex w-full max-w-330 flex-1 px-4 sm:px-6">
			<main class="mx-auto flex w-full max-w-240 flex-col gap-5 py-6 xl:mx-0">
				<slot />
			</main>

			<aside class="hidden shrink-0 grow basis-0 pt-6 pl-5 xl:block">
				{hasToc && <slot name="toc" />}
			</aside>
		</div>

		{/* Full-width footer */}
		<LuFooter />
	</div>
	<LuSearch client:idle />
</BaseLayout>
