---
import { getEntry } from 'astro:content';
import Logo from '@components/levelup/Logo.astro';
import MagnifyingGlassIcon from '~icons/heroicons/magnifying-glass-20-solid';

const site = await getEntry('site', 'config');
const description = site?.data.description ?? '';
---

<header class="lu-header w-full">
	<div
		class="mx-auto flex w-full items-center justify-between gap-4 px-6 py-4 sm:px-8"
	>
		<a href="/" class="shrink-0" aria-label="LevelUp home">
			<Logo class="h-8 w-auto text-white sm:h-9" />
		</a>
		<div class="flex items-center gap-4">
			<p
				class="hidden text-right font-serif text-base italic text-white sm:block"
			>
				{description}
			</p>
			<button
				type="button"
				aria-label="Search"
				class="flex items-center gap-2 rounded-full border border-white/70 px-3 py-1.5 text-sm text-white transition-colors hover:bg-white/20"
				onclick="window.dispatchEvent(new CustomEvent('lu-open-search'))"
			>
				<MagnifyingGlassIcon class="h-5 w-5" />
				<span class="hidden sm:inline">Search</span>
			</button>
		</div>
	</div>
</header>
