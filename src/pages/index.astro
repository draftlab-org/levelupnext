---
import SectionCard from '@components/levelup/SectionCard.astro';
import LevelUpLayout from '@layouts/LevelUpLayout.astro';

const cards = [
  {
    title: 'Getting Started',
    href: '/community/getting-started/',
    text: 'Start here to learn how to use and adapt LevelUp resources for your digital safety trainings.',
  },
  {
    title: 'News & Updates',
    href: '/news/',
    text: 'Stay informed of new content & materials, site updates, upcoming events, and other news.',
  },
  {
    title: 'Contribute & Contact',
    href: '/community/contribute/',
    text: 'Get in touch to help improve LevelUp — share training content with other trainers, provide feedback, and more.',
  },
];
---

<LevelUpLayout
	title="LevelUp"
	description="Resources for the global digital safety training community."
>
	{
		cards.map((card) => (
			<SectionCard>
				<div class="lu-home-card">
					<h2 class="text-3xl md:text-4xl">
						<a href={card.href}>{card.title}</a>
					</h2>
					<p class="mt-4 text-lg">
						{card.text}{' '}
						<a
							href={card.href}
							class="ml-1 inline-block rounded border border-primary-500 px-2 py-0.5 text-sm text-primary-500 hover:bg-primary-500 hover:text-white"
							aria-label={`Go to ${card.title}`}
						>
							&raquo;
						</a>
					</p>
				</div>
			</SectionCard>
		))
	}
</LevelUpLayout>
