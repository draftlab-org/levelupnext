---
import SectionCard from '@components/levelup/SectionCard.astro';
import LevelUpLayout from '@layouts/LevelUpLayout.astro';
---

<LevelUpLayout
	title="Page Not Found"
	description="The page you're looking for doesn't exist."
>
	<SectionCard>
		<h1 class="text-5xl md:text-6xl">404</h1>
		<p class="mt-4 text-lg">
			The page you're looking for doesn't exist or has been moved.
		</p>
		<p class="mt-6">
			<a
				href="/"
				class="inline-block rounded border border-primary-500 px-4 py-2 text-primary-500 hover:bg-primary-500 hover:text-white"
			>
				Go back home
			</a>
		</p>
	</SectionCard>
</LevelUpLayout>
